@model Login

@{
    ViewData["Title"] = "Iniciar sesion";
}

<h1>@ViewData["Title"]</h1>

<div class="row main-flex-center">

    <div class="col-md-4">
        <form asp-action="IniciarSesion">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control"></>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <label asp-for="Password" class="control-label"></label>
            <input asp-for="Password" class="form-control"></>
            <span asp-validation-for="Password" class="text-danger"></span>
            <div class="form-group">
                <label asp-for="Recordarme" class="form-check-label"></label>
                <input asp-for="Recordarme" class="form-check-label"></>
                <span asp-validation-for="Recordarme" class="text-danger"></span>
            </div>

            <div class="form-group pt-3 d-flex justify-content-center">
                <input type="submit" value="iniciar sesión" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}