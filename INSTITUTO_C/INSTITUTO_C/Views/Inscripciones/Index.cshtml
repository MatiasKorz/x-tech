@model IEnumerable<INSTITUTO_C.Models.Inscripcion>

@{
    ViewData["Title"] = "Inscripciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Inscripciones</h1>
    <a asp-action="Create" class="btn btn-primary">
        + Create New
    </a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.MateriaCursada)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Alumno)
            </th>
            <th>Nota</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            var calificacion = item?.Calificacion;
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.MateriaCursada.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Alumno.Apellido)
                </td>
                <td>
                    @if (calificacion != null)
                    {
                        <span>@calificacion.Nota</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                @if (User.IsInRole("Empleado"))
                {
                    <td>
                        <a asp-action="Edit"
                           asp-route-alumnoId="@item.AlumnoId"
                           asp-route-materiaCursadaId="@item.MateriaCursadaId">
                            Edit
                        </a> |
                        <a asp-action="Details"
                           asp-route-alumnoId="@item.AlumnoId"
                           asp-route-materiaCursadaId="@item.MateriaCursadaId">
                            Details
                        </a> |
                        <a asp-action="Delete"
                           asp-route-alumnoId="@item.AlumnoId"
                           asp-route-materiaCursadaId="@item.MateriaCursadaId">
                            Delete
                        </a>
                    </td>
                }
                else if (User.IsInRole("Alumno"))
                {
                    <td>
                        @{
                            var calificacionActual = item.Calificacion; // 

                            if (calificacionActual != null && calificacionActual.Nota == Nota.Pendiente)
                            {
                                <form asp-action="Baja" method="post" style="display:inline">
                                    <input type="hidden" name="materiaCursadaId" value="@item.MateriaCursadaId" />
                                    <button type="submit" class="btn btn-warning btn-sm"
                                            onclick="return confirm('¿Seguro que querés darte de baja de esta materia?')">
                                        Baja
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Calificaciones"
                                   asp-action="Details"
                                   asp-route-alumnoId="@item.AlumnoId"
                                   asp-route-materiaCursadaId="@item.MateriaCursadaId"
                                   class="btn btn-info btn-sm">
                                    Ver nota
                                </a>
                            }
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>