@model INSTITUTO_C.Models.Inscripcion

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Inscripcion</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.MateriaCursada)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MateriaCursada.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Alumno)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Alumno.Apellido)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit"
       asp-route-alumnoId="@Model.AlumnoId"
       asp-route-materiaCursadaId="@Model.MateriaCursadaId">
        Edit
    </a> |
    <a asp-action="Delete"
       asp-route-alumnoId="@Model.AlumnoId"
       asp-route-materiaCursadaId="@Model.MateriaCursadaId">
        Delete
    </a> |
    <a asp-action="Index">Back to List</a>
</div>
