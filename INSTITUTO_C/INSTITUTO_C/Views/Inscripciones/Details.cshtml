@model INSTITUTO_C.Models.Inscripcion

@{
    ViewData["Title"] = "Details";
}

<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>Detalles Inscripcion</h4>
        <hr />
        <dl class="row main-flex-center">
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.MateriaCursada)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.MateriaCursada.Nombre)
            </dd>
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Alumno)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Alumno.Apellido)
            </dd>
        </dl>
        <div class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a class="btn btn-primary" asp-action="Index">Volver</a>
            <a asp-action="Edit"
               asp-route-alumnoId="@Model.AlumnoId"
               asp-route-materiaCursadaId="@Model.MateriaCursadaId">
                Editar
            </a>
            <a asp-action="Delete"
               asp-route-alumnoId="@Model.AlumnoId"
               asp-route-materiaCursadaId="@Model.MateriaCursadaId">
                Eliminar
            </a>
        </div>
    </div>
</div>


