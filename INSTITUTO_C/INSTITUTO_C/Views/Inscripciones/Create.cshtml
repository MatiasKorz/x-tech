@model INSTITUTO_C.Models.Inscripcion

@{
    ViewData["Title"] = "Create";
  
}

<h1>Crear</h1>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>Inscribirse</h4>
        <hr />
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MateriaCursadaId" class="control-label"></label>
                <select asp-for="MateriaCursadaId" class="form-control" asp-items="ViewBag.MateriaCursadaId">
                    <option value="">Seleccione una cursada</option>
                </select>
                <span asp-validation-for="MateriaCursadaId" class="text-danger"></span>
            </div>
            @if (User.IsInRole("Empleado"))
            {
                <div class="form-group">
                    <label asp-for="AlumnoId" class="control-label"></label>
                    <select asp-for="AlumnoId" class="form-control" asp-items="ViewBag.AlumnoId">
                        <option value="">Seleccione un alumno</option>
                    </select>
                    <span asp-validation-for="AlumnoId" class="text-danger"></span>
                </div>
            }

            <div class="form-group pt-3 d-flex justify-content-between align-content-center">
                <a class="btn btn-primary" asp-action="Index">Volver</a>
                <input type="submit" value="Inscribirse" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
