﻿@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -X-Tech</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MisEstilos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Detalles.css" asp-append-version="true" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">

                    @* SIN HOME YA QUE UTILIZAREMOS EL LOGO *@
                    @* <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    </ul> *@

                    @if (signInManager.IsSignedIn(User))
                    {
                        <ul class="navbar-nav flex-grow-1 justify-content-center">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Personas" asp-action="Details" asp-route-id="@User.FindFirstValue(ClaimTypes.NameIdentifier)">Mi Perfil</a>
                            </li>

                        @if (User.IsInRole("Empleado"))
                        {
                            //ADMINISTRACION TOTAL - TODAS LAS SECCIONES

                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Personas" asp-action="Index">Personas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Alumnos" asp-action="Index">Alumnos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Empleados" asp-action="Index">Empleados</a>
                                </li>

                                }

                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Profesores" asp-action="Index">Profesores</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Carreras" asp-action="Index">Carreras</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Materias" asp-action="Index">Materias</a>
                                </li>
                            </ul>


                        if (!User.IsInRole("Empleado")) //LO VEN TANTO PROFES COMO ALUMNOS
                        {

                            <ul class="navbar-nav flex-grow-1 justify-content-center">
                                    <li class="nav-item">
                                        <a class="nav-link text-white" asp-area="" asp-controller="MateriasCursadas" asp-action="Actuales" asp-route-personaid="@User.FindFirstValue(ClaimTypes.NameIdentifier)">Cursadas Actuales</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-white" asp-area="" asp-controller="MateriasCursadas" asp-action="Finalizadas" asp-route-personaid="@User.FindFirstValue(ClaimTypes.NameIdentifier)">Cursadas Finalizadas</a>
                                    </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Calificaciones" asp-action="Index" asp-route-personaid="@User.FindFirstValue(ClaimTypes.NameIdentifier)">Calificaciones</a>
                                </li>

                            </ul>
                        }
                        else if (User.IsInRole("Alumno"))
                        {

                            <ul class="navbar-nav flex-grow-1 justify-content-center">
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Inscripciones" asp-action="Index" asp-route-alumnoId="@User.FindFirstValue(ClaimTypes.NameIdentifier)">Mis Inscripciones</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Inscripciones" asp-action="Create">Inscribirme</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Calificaciones" asp-action="Index">Mis Calificaciones</a>
                                </li>
                            </ul>

                        }
                        if (User.IsInRole("Empleado"))
                        {

                            <ul class="navbar-nav flex-grow-1 justify-content-center">
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Inscripciones" asp-action="Index">Inscripciones</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="MateriasCursadas" asp-action="Index">Cursadas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Calificaciones" asp-action="Index">Calificaciones</a>
                                </li>

                            </ul>
                        }


                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link text-white btn btn-submit " asp-area="" asp-controller="Account" asp-action="CerrarSesion">Cerrar sesión</a>
                            </li>
                        </ul>


                    }
                    else
                    {
                        //SIN LOGIN SOLO REGISTRARSE E INICIAR SESION Y DATOS DE CARRERAS MATERIAS Y PROFESORES
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Carreras" asp-action="Index">Carreras</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Materias" asp-action="Index">Materias</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Profesores" asp-action="Index">Profesores</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white btn btn-submit" asp-area="" asp-controller="Account" asp-action="Registrar">Registrarse</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white btn btn-submit" asp-area="" asp-controller="Account" asp-action="IniciarSesion">Iniciar sesión</a>
                            </li>


                        </ul>
                    }
                    
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        <div class="main-style">
            @RenderBody()
        </div>
    </main>

    <footer class="footer text-muted">
        <span class="text-white"> &copy; 2025 -X-Tech</span> <a asp-action="Seed" asp-controller="PreCarga" class="btn btn-sm btn-info">Pre Carga Db</a>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
