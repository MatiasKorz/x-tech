@model INSTITUTO_C.Models.Carrera

@{
    ViewData["Title"] = "Details";
}

<<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>Detalles Carrera</h4>
        <hr />
        <dl class="row main-flex-center">
            <dt class = "col-sm-3">
                @Html.DisplayNameFor(model => model.Nombre)
            </dt>
            <dd class = "col-sm-9">
                @Html.DisplayFor(model => model.Nombre)
            </dd>
        </dl>
        @if (Model.Materias != null && Model.Materias.Any())
        {
            <table class="table table-striped mt-2">
                <thead class="bg-light">
                    <tr class="text-white">
                        <th>Nombre</th>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th></th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var materia in Model.Materias)
                    {
                        <tr>
                            <td>@materia.Nombre</td>
                            <td>@materia.CodigoMateria</td>
                            <td>@materia.Descripcion</td>

                            <td>
                                <a class="btn btn-sm btn-primary"
                                   asp-controller="Materias"
                                   asp-action="Details"
                                   asp-route-id="@materia.Id"
                                   asp-route-returnUrl="Carreras">
                                    Ver
                                </a>

                                <a class="btn btn-sm btn-primary ms-2"
                                    asp-controller="Inscripciones"
                                    asp-action="Create"
                                    asp-route-materiaId="@materia.Id">
                                    Inscribirme
                                </a>
                            </td>
                            

                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Esta carrera aún no tiene materias registradas.</p>
        }

        <div class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a class="btn btn-primary" asp-action="Index">Volver</a>
     @if (User.IsInRole("Empleado"))
                {

            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.Id">Editar</a>

                }
        </div>
    </div>
</div>

