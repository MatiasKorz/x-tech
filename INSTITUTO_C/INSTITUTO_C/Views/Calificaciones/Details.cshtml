@model INSTITUTO_C.Models.Calificacion

@{
    ViewData["Title"] = "Details";
}

<h1>Detalles de Calificación</h1>

<div>
    <h4>Calificación</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Fecha)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Fecha)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Nota)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nota)
        </dd>

        <dt class="col-sm-2">
            Profesor
        </dt>
        <dd class="col-sm-10">
            @Model.Profesor.Apellido
        </dd>

        <dt class="col-sm-2">
            Materia
        </dt>
        <dd class="col-sm-10">
            @Model.Inscripcion.MateriaCursada.Nombre
        </dd>

        <dt class="col-sm-2">
            Alumno
        </dt>
        <dd class="col-sm-10">
            @Model.Alumno.Apellido
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit"
       asp-route-alumnoId="@Model.AlumnoId"
       asp-route-materiaCursadaId="@Model.MateriaCursadaId">Editar</a> |
    <a asp-action="Index">Volver al listado</a>
</div>
