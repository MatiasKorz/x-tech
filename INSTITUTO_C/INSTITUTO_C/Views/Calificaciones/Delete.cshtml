@model INSTITUTO_C.Models.Calificacion

@{
    ViewData["Title"] = "Delete";
}

<div class="row main-flex-center">
    <div class="col-md-6">
        <h4>¿Estas seguro de eliminar la calificacion?</h4>
        <hr />
        <dl class="row main-flex-center">
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Fecha)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Fecha)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Nota)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Nota)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.ProfesorId)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.ProfesorId)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.MateriaCursadaId)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.MateriaCursadaId)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.AlumnoId)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.AlumnoId)
            </dd>
        </dl>

        <form asp-action="Delete" method="post" class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a asp-action="Index" class="btn btn-primary">Volver</a>
            <input type="hidden" asp-for="AlumnoId" />
            <input type="hidden" asp-for="MateriaCursadaId" />
            <input type="submit" value="Eliminar" class="btn btn-delete" />
        </form>
    </div>

</div>
