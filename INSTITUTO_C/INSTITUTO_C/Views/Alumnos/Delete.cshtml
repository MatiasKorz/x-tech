@model INSTITUTO_C.Models.Alumno

@{
    ViewData["Title"] = "Delete";
}

<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>¿Estas seguro de eliminar?</h4>
        <hr />
        <dl class="row main-flex-center">

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.NumeroMatricula)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.NumeroMatricula)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Carrera)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Carrera.Nombre)
            </dd>
            <dt class="col-sm-3 no-link-style">
                @Html.DisplayNameFor(model => model.Email)
            </dt>
            <dd class="col-sm-9 no-link-style">
                @Html.DisplayFor(model => model.Email)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.FechaAlta)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.FechaAlta)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Nombre)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Nombre)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Apellido)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Apellido)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.DNI)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.DNI)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Telefono)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Telefono)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Direccion)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Direccion)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Activo)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Activo)
            </dd>
        </dl>

        <form asp-action="Delete" class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a asp-action="Index" class="btn btn-primary">Volver</a>
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Eliminar" class="btn btn-delete" />
            
        </form>
</div>
