@model INSTITUTO_C.Models.Materia

@{
    ViewData["Title"] = "Details";
}

<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>Detalles Materia</h4>
        <hr />
        <dl class="row main-flex-center">
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Carrera)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Carrera.Nombre)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Nombre)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Nombre)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.CodigoMateria)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.CodigoMateria)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Descripcion)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Descripcion)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.CupoMaximo)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.CupoMaximo)
            </dd>

        </dl>
     @if (User.IsInRole("Empleado"))
                {
        <div class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a class="btn btn-primary" asp-action="Index">Volver</a>
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model?.Id">Editar</a>
        </div>
                }
    </div>
</div>

