@{
    ViewData["Title"] = "Instituto";
}
@if(ViewBag.Mensaje != null)
{
    <div>
        <p class="text-info">@ViewBag.Mensaje</p>
    </div>
}


<main>
    <div class="container">

        <div class="text-center">
            <h1 class="display-3" style="color: #667eea; font-weight: 700">Bienvenido a X-Tech</h1>
            <p class="lead display-6">Instituto de Educación Tecnológica</p>
        </div>

        <div class="info-section">
            <h3 class="text-center mb-4"><i class="fas fa-graduation-cap"></i> Sobre Nosotros</h3>
            <p class="text-center mb-4">
                El Instituto X-Tech es una institución líder en formación tecnológica, dedicada a preparar
                a los profesionales del futuro. Con más de 13 años de experiencia, ofrecemos carreras
                especializadas en las áreas más demandadas de la industria tech.
            </p>
            <div class="row mt-4">
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="stat-box">
                        <h4>2,500+</h4>
                        <p>Estudiantes Activos</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="stat-box">
                        <h4>30+</h4>
                        <p>Profesores Expertos</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="stat-box">
                        <h4>25+</h4>
                        <p>Materias Disponibles</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="stat-box">
                        <h4>95%</h4>
                        <p>Inserción Laboral</p>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="text-center mb-4" style="color: #667eea; font-weight: 700;">Nuestras Especialidades</h2>

        <div class="row g-3 mb-5">

            @* FRONTEND *@
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card career-card">
                    <div class="card-header frontend-header">
                        <i class="fas fa-palette"></i>
                        <h4 class="mb-0">Frontend Development</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Conviértete en un experto en interfaces de usuario y experiencia visual.</p>
                        <ul>
                            <li><i class="fas fa-check-circle"></i> HTML5, CSS3, JavaScript</li>
                            <li><i class="fas fa-check-circle"></i> React, Vue, Angular</li>
                            <li><i class="fas fa-check-circle"></i> Responsive Design</li>
                            <li><i class="fas fa-check-circle"></i> UI/UX Principles</li>
                            <li><i class="fas fa-check-circle"></i> Web Performance</li>
                        </ul>
                        <div class="mt-3">
                            <span class="badge bg-primary">3 años</span>
                            <span class="badge bg-secondary">Turno Mañana/Tarde</span>
                        </div>
                    </div>
                </div>
            </div>

            @* BACKEND *@
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card career-card">
                    <div class="card-header backend-header">
                        <i class="fas fa-server"></i>
                        <h4 class="mb-0">Backend Development</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Domina la lógica del servidor y la gestión de datos.</p>
                        <ul>
                            <li><i class="fas fa-check-circle"></i> C#, .NET Core, Node.js</li>
                            <li><i class="fas fa-check-circle"></i> APIs REST & GraphQL</li>
                            <li><i class="fas fa-check-circle"></i> Bases de Datos SQL/NoSQL</li>
                            <li><i class="fas fa-check-circle"></i> Microservicios</li>
                            <li><i class="fas fa-check-circle"></i> Seguridad y Autenticación</li>
                        </ul>
                        <div class="mt-3">
                            <span class="badge bg-danger">3 años</span>
                            <span class="badge bg-secondary">Turno Tarde/Noche</span>
                        </div>
                    </div>
                </div>
            </div>

           @* QA Y TESTING *@
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card career-card">
                    <div class="card-header testing-header">
                        <i class="fas fa-bug"></i>
                        <h4 class="mb-0">QA & Testing</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Garantiza la calidad del software con testing profesional.</p>
                        <ul>
                            <li><i class="fas fa-check-circle"></i> Testing Manual y Automatizado</li>
                            <li><i class="fas fa-check-circle"></i> Selenium, Cypress, Playwright</li>
                            <li><i class="fas fa-check-circle"></i> Performance Testing</li>
                            <li><i class="fas fa-check-circle"></i> CI/CD Integration</li>
                            <li><i class="fas fa-check-circle"></i> Metodologías Ágiles</li>
                        </ul>
                        <div class="mt-3">
                            <span class="badge bg-info">2.5 años</span>
                            <span class="badge bg-secondary">Turno Mañana</span>
                        </div>
                    </div>
                </div>
            </div>

            @* INTELIGENCIA ARTIFICIAL *@
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card career-card">
                    <div class="card-header ai-header">
                        <i class="fas fa-brain"></i>
                        <h4 class="mb-0">Inteligencia Artificial</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Desarrolla soluciones inteligentes con IA y Machine Learning.</p>
                        <ul>
                            <li><i class="fas fa-check-circle"></i> Python, TensorFlow, PyTorch</li>
                            <li><i class="fas fa-check-circle"></i> Machine Learning</li>
                            <li><i class="fas fa-check-circle"></i> Deep Learning & NLP</li>
                            <li><i class="fas fa-check-circle"></i> Computer Vision</li>
                            <li><i class="fas fa-check-circle"></i> Modelos Generativos</li>
                        </ul>
                        <div class="mt-3">
                            <span class="badge bg-success">4 años</span>
                            <span class="badge bg-secondary">Turno Tarde</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</main>
