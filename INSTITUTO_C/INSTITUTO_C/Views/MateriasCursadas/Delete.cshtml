@model INSTITUTO_C.Models.MateriaCursada

@{
    ViewData["Title"] = "Delete";
}

<div class="row main-flex-center">

    <div class="col-md-6">
        <h4>¿Estas seguro de eliminar Materia cursada?</h4>
        <hr />
        <dl class="row main-flex-center">
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Materia)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Materia.CodigoMateria)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.CodigoCursada)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.CodigoCursada)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Anio)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Anio)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Cuatrimestre)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Cuatrimestre)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Activo)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Activo)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Profesor)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Profesor.Apellido)
            </dd>

        </dl>
    
        <form asp-action="Delete" class="form-group pt-3 d-flex justify-content-between align-content-center">
            <a asp-action="Index" class="btn btn-primary">Volver</a>
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Eliminar" class="btn btn-delete" />
        </form>
    </div>

</div>
