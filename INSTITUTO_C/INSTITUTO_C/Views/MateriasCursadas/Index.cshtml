@model IEnumerable<INSTITUTO_C.Models.MateriaCursada>
@using INSTITUTO_C.Helpers
@{
    ViewData["Title"] = "MateriaCursada";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Materias Cursadas</h1>
                        @if (User.IsInRole(Configs.Empleado))
                {
    <a asp-action="Create" class="btn btn-primary">
        + Crear cursada
    </a>
                }
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Materia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CodigoCursada)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Anio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cuatrimestre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Activo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Profesor)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Materia.CodigoMateria)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CodigoCursada)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Anio.Year)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Cuatrimestre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Activo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Profesor.Apellido)
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success btn-sm">Detalles</a>
                
                    @if (User.IsInRole(Configs.Empleado))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                }

                </td>
        </tr>
}
    </tbody>
</table>
