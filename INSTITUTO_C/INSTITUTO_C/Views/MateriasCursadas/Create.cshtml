@model INSTITUTO_C.Models.MateriaCursada

@{
    ViewData["Title"] = "Create";
}

<h1>Crear</h1>

<h4>MateriaCursada</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MateriaId" class="control-label"></label>
                <select asp-for="MateriaId" class="form-control" asp-items="ViewBag.MateriaId">
                    <option value="">Seleccione una materia</option>
                </select>
                <span asp-validation-for="MateriaId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CodigoCursada" class="control-label"></label>
                <select asp-for="CodigoCursada" class="form-control"
                        asp-items="Html.GetEnumSelectList<CodigoCursada>()">
                    <option value="">Seleccione un código</option>
                </select>
                <span asp-validation-for="CodigoCursada" class="text-danger"></span>
            </div>
           
            <div class="form-group">
                <label asp-for="Cuatrimestre" class="control-label"></label>
                <select asp-for="Cuatrimestre" class="form-control">
                    <option value="">Seleccione cuatrimestre</option>
                    <option value="1">1° Cuatrimestre</option>
                    <option value="2">2° Cuatrimestre</option>
                </select>
                <span asp-validation-for="Cuatrimestre" class="text-danger"></span>
            </div>
@*             <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Activo" /> @Html.DisplayNameFor(model => model.Activo)
                </label>
            </div> *@
            <div class="form-group">
                <label asp-for="ProfesorId" class="control-label"></label>
                <select asp-for="ProfesorId" class="form-control" asp-items="ViewBag.ProfesorId">
                    <option value="">Seleccione un profesor</option>
                </select>
                <span asp-validation-for="ProfesorId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
